{
  "uid": "litter-system-resources",
  "title": "Litter Detection — System Resources",
  "tags": ["system", "resources"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "OTel Collector CPU (%)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "rate(otelcol_process_cpu_seconds_total[5m]) * 100"
        }
      ]
    },
    {
      "id": 2,
      "title": "OTel Collector Memory (RSS)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "otelcol_process_memory_rss"
        }
      ]
    },
    {
      "id": 3,
      "title": "Prometheus Memory (RSS)",
      "type": "stat",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "process_resident_memory_bytes"
        }
      ]
    },
    {
      "id": 4,
      "title": "Prometheus Goroutines",
      "type": "stat",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "go_goroutines"
        }
      ]
    },
    {
      "id": 5,
      "title": "Prometheus Scrape Duration (avg)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "rate(prometheus_target_scrape_duration_seconds_sum[5m]) / rate(prometheus_target_scrape_duration_seconds_count[5m])"
        }
      ]
    }
  ]
}
