{
  "uid": "litter-training-operations",
  "title": "Litter Detection Training — Operations & Latency",
  "tags": ["training", "operations"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "Average Training Loss (Train vs Validation)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "training_loss_train_sum / training_loss_train_count",
          "legendFormat": "Train Loss"
        },
        {
          "expr": "training_loss_validation_sum / training_loss_validation_count",
          "legendFormat": "Validation Loss"
        }
      ]
    },
    {
      "id": 2,
      "title": "Average IoU (Train vs Validation)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "training_iou_train_sum / training_iou_train_count",
          "legendFormat": "Train IoU"
        },
        {
          "expr": "training_iou_validation_sum / training_iou_validation_count",
          "legendFormat": "Validation IoU"
        }
      ]
    },
    {
      "id": 3,
      "title": "Average Epoch Duration (seconds)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "training_epoch_time_seconds_sum / training_epoch_time_seconds_count",
          "legendFormat": "Epoch Time"
        }
      ]
    },
    {
      "id": 4,
      "title": "Epochs Completed",
      "type": "stat",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "training_epochs_completed_total",
          "legendFormat": "Epochs"
        }
      ]
    },
    {
      "id": 5,
      "title": "Recorded Loss Samples",
      "type": "stat",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "training_loss_train_count",
          "legendFormat": "Samples"
        }
      ]
    },
    {
      "id": 6,
      "title": "Recorded IoU Samples",
      "type": "stat",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "targets": [
        {
          "expr": "training_iou_train_count",
          "legendFormat": "Samples"
        }
      ]
    }
  ]
}
